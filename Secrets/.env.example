# Secrets Configuration Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================================================
# Vaultwarden Configuration
# ============================================================================

# Your Vaultwarden server URL (self-hosted Bitwarden)
VAULTWARDEN_URL=https://vault.yourcompany.com

# API Key credentials (get from Organization Settings > API Key in Vaultwarden)
# SECURITY: Store these in Windows Credential Manager or Vaultwarden itself
VAULTWARDEN_CLIENT_ID=
VAULTWARDEN_CLIENT_SECRET=

# ============================================================================
# Azure Key Vault Configuration (Future Use)
# ============================================================================

# Azure Key Vault name
AZURE_KEYVAULT_NAME=

# Azure Tenant ID (from Azure Portal > Active Directory > Tenant ID)
AZURE_TENANT_ID=

# Azure Subscription ID (from Azure Portal > Subscriptions)
AZURE_SUBSCRIPTION_ID=

# Service Principal Application ID (if using SPN authentication)
AZURE_APPLICATION_ID=

# ============================================================================
# Credential Storage Configuration
# ============================================================================

# Where to store credential XML files (outside project directory!)
# RECOMMEND: Store in a secure location outside your project folder
# Example: C:\Scripts\Secrets (create this folder manually)
CREDENTIAL_PATH=C:\Scripts\Secrets

# ============================================================================
# Security Notes
# ============================================================================
# 
# 1. NEVER commit .env to version control - add to .gitignore
# 2. Store sensitive values (API keys, secrets) in Vaultwarden or Windows Credential Manager
# 3. Use DPAPI encryption for single-machine scripts
# 4. Use AES encryption with keys stored in Vaultwarden for cross-machine scripts
# 5. Audit credential usage - track who uses what and when
#
